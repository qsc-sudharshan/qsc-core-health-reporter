# ─────────────────────────────────────────────────────────────────────────────
# QSC Core Health Reporter — Environment Variables
# Copy this file to .env for local development.
# In GitHub Actions, set these as repository Secrets (Settings → Secrets → Actions).
# ─────────────────────────────────────────────────────────────────────────────

# ── Grafana Cloud — Prometheus ────────────────────────────────────────────────
# Found in: Grafana Cloud Portal → Prometheus → Details
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom

# ── Grafana Cloud — Loki ──────────────────────────────────────────────────────
# Found in: Grafana Cloud Portal → Loki → Details
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net

# ── Grafana Cloud — Auth ──────────────────────────────────────────────────────
# Instance ID (numeric) — visible in datasource settings (User field under Basic Auth)
# Your instance ID: 2417991
GRAFANA_INSTANCE_ID=2417991

# Service Account Token (recommended over deprecated API Keys since Grafana 9+)
# How to create:
#   1. Go to https://sleestack.grafana.net/org/serviceaccounts
#   2. Click "Add service account"
#   3. Name it (e.g. "core-health-reporter"), set Role = Viewer
#   4. Click the service account → "Add service account token"
#   5. Copy the token (starts with glsa_...)
GRAFANA_SERVICE_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Confluence ────────────────────────────────────────────────────────────────
# Your Atlassian domain (include /wiki)
CONFLUENCE_BASE_URL=https://qsc.atlassian.net/wiki

# Atlassian account email
CONFLUENCE_EMAIL=your-email@qsc.com

# Atlassian API token — create at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your_atlassian_api_token

# Confluence space key (e.g. BGLR)
CONFLUENCE_SPACE_KEY=BGLR

# Page ID of the parent "Core Health Reports" page
# Get it from the URL: /wiki/spaces/BGLR/pages/PAGE_ID/
CONFLUENCE_PARENT_PAGE_ID=4504158273

# ── Report Target ─────────────────────────────────────────────────────────────
# The core to report on (overrides the default in main.py)
CORE_ID=eternia-Core24-d447
